@{
  ViewData["Title"] = "Chi tiết phim - Quốc Phim";
}

  <div class="container section">
    <div id="movieDetail" class="movie-detail"></div>

    <div id="showtimesSection" style="margin:2rem 0">
      <h3 style="color:white;margin-bottom:1rem">Lịch chiếu</h3>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;align-items:center;margin-bottom:1rem">
        <div>
          <label style="color:#888;margin-right:0.5rem">Ngày</label>
          <input id="showtimeDate" type="date" class="form-control" style="max-width:180px;display:inline-block">
        </div>
        <div>
          <label style="color:#888;margin-right:0.5rem">Rạp</label>
          <select id="showtimeCinema" class="form-control" style="max-width:200px;display:inline-block">
            <option value="">Tất cả rạp</option>
          </select>
        </div>
      </div>
      <div id="showtimesList" class="showtimes-list" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:1rem"></div>
    </div>

    <div id="reviewsSection">
      <h3 style="color:white;margin:2rem 0">Đánh giá</h3>
      <div id="reviewsList" class="reviews-list"></div>
      <div id="reviewLoginPrompt" style="display:none;margin-top:2rem;padding:1rem;background:rgba(229,9,20,0.1);border-radius:8px">
      <p style="color:#e5e5e5;margin-bottom:0.5rem">Đăng nhập để đánh giá phim</p>
      <a href="/login?redirect=%2Fpages%2Fmovie-detail%3Fid%3D" id="reviewLoginLink" class="btn btn-primary">Đăng nhập</a>
    </div>
    <div id="addReviewForm" style="display:none;margin-top:2rem">
        <div class="auth-box" style="max-width:500px">
          <h4 style="color:white">Viết đánh giá</h4>
          <div class="form-group">
            <label>Điểm (1-5)</label>
            <div class="rating-stars" id="reviewRatingStars" data-rating="5">
              <span class="star" data-value="1">★</span>
              <span class="star" data-value="2">★</span>
              <span class="star" data-value="3">★</span>
              <span class="star" data-value="4">★</span>
              <span class="star" data-value="5">★</span>
            </div>
            <input type="hidden" id="reviewRating" value="5">
          </div>
          <div class="form-group">
            <label>Bình luận</label>
            <textarea id="reviewComment" class="form-control" rows="3"></textarea>
          </div>
          <button class="btn btn-primary" onclick="submitReview()">Gửi đánh giá</button>
        </div>
      </div>
    </div>
  </div>

@section Scripts {
  <script src="/js/auth.js"></script>
  <script src="/js/movie-detail.js"></script>
}
