@{
  ViewData["Title"] = "Quốc Phim - Đặt vé xem phim";
  ViewData["FooterText"] = "© Quốc Phim - Rạp chiếu phim";
}

  <section class="hero-section">
    <div class="container">
      <h1>Đặt vé xem phim nhanh chóng</h1>
      <p>Chọn phim, suất chiếu, ghế ngồi và thanh toán trực tuyến</p>
      <a class="btn btn-primary" href="/pages/booking">Đặt vé ngay</a>
    </div>
  </section>

  <section class="featured-movies">
    <div class="container">
      <h2>Phim đang chiếu</h2>
      <div id="featuredMovies" class="movies-grid"></div>
      <h2 style="margin-top:3rem">Phim sắp chiếu</h2>
      <div id="comingSoonMovies" class="movies-grid"></div>
    </div>
  </section>

  <button id="chatToggleBtn" class="chat-toggle-btn" type="button" aria-label="Mở chat AI">Chat AI</button>

  <section id="chatWidget" class="chat-widget" aria-live="polite">
    <div class="chat-header">
      <h3>Trợ lý AI Quốc Phim</h3>
      <button id="chatCloseBtn" class="chat-close-btn" type="button" aria-label="Đóng chat">×</button>
    </div>
    <div id="chatMessages" class="chat-messages">
      <div class="chat-message bot">
        Xin chào! Mình có thể giúp bạn tra cứu phim, suất chiếu và rạp từ dữ liệu hệ thống.
      </div>
    </div>
    <form id="chatForm" class="chat-form">
      <input
        id="chatInput"
        class="chat-input"
        type="text"
        placeholder="Ví dụ: có bao nhiêu cinema?"
        maxlength="300"
        autocomplete="off"
      >
      <button id="chatSendBtn" class="btn btn-primary" type="submit">Gửi</button>
    </form>
  </section>

@section Scripts {
  <script src="/js/auth.js"></script>
  <script src="/js/main.js"></script>
}
