@{
  ViewData["Title"] = "Hồ sơ - Quốc Phim";
}

  <div class="container section">
    <h2>Quản lý hồ sơ</h2>
    <div id="profileError" class="auth-error" style="display:none;margin-bottom:1rem"></div>
    <div class="auth-box" style="max-width:500px">
      <form id="profileForm">
        <div class="form-group">
          <label>Tên đăng nhập</label>
          <input class="form-control" type="text" id="username" readonly disabled style="background:#333;color:#999">
        </div>
        <div class="form-group">
          <label>Họ tên</label>
          <input class="form-control" type="text" id="fullName" placeholder="Họ và tên">
        </div>
        <div class="form-group">
          <label>Email</label>
          <input class="form-control" type="email" id="email" placeholder="Email" required>
        </div>
        <div class="form-group">
          <label>Số điện thoại</label>
          <input class="form-control" type="text" id="phone" placeholder="Số điện thoại">
        </div>
        <hr style="border-color:#333;margin:1.5rem 0">
        <h4 style="color:white;margin-bottom:1rem">Đổi mật khẩu (để trống nếu không đổi)</h4>
        <div class="form-group">
          <label>Mật khẩu hiện tại</label>
          <input class="form-control" type="password" id="currentPassword" placeholder="Mật khẩu hiện tại">
        </div>
        <div class="form-group">
          <label>Mật khẩu mới</label>
          <input class="form-control" type="password" id="newPassword" placeholder="Mật khẩu mới">
        </div>
        <div class="form-group">
          <label>Xác nhận mật khẩu mới</label>
          <input class="form-control" type="password" id="newPassword2" placeholder="Nhập lại mật khẩu mới">
        </div>
        <button class="btn btn-primary" type="submit" style="width:100%">Cập nhật</button>
      </form>
    </div>
  </div>

@section Scripts {
  <script src="/js/auth.js"></script>
  <script src="/js/profile.js"></script>
}
